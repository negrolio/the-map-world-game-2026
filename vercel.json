{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "redirects": [
    {
      "source": "/the-map-world-game-2026",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/the-map-world-game-2026/:path*",
      "destination": "/:path*",
      "permanent": false
    }
  ]
}
