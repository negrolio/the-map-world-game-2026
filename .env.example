# Copiar a .env.local para desarrollo local (no commitear .env.local).

# Origen de la API al usar `npm run dev:api` (vercel dev), típicamente puerto 3000.
VITE_API_BASE_URL=http://localhost:3000

# Orígenes permitidos para CORS en handlers api/ (lista separada por comas).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limit en /api/v1/countries/:iso2/learn (activo en VERCEL_ENV=preview|production).
# Local: desactivado salvo RATE_LIMIT_ENABLED=1. Apagar en Vercel: RATE_LIMIT_DISABLED=1
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000

# Secretos de servidor (no incluir en el bundle Vite). Solo configurar en
# `.env.local` para `vercel dev` y en las env vars del proyecto en Vercel.
#
# GEMINI_API_KEY: clave de Google AI Studio para el modo AI trivia.
# Si está ausente o vacía, el handler `/api/v1/prompts/generate` responde
# `LLM_UNAVAILABLE` (no rompe el bootstrap; los demás endpoints siguen
# funcionando).
# GEMINI_API_KEY=
#
# USE_FAKE_LLM=1 fuerza al backend a usar el adaptador fake determinista
# (server/prompts/llm-client-fake.ts). Útil en local y CI para evitar costos
# de proveedor. NO usar en `production`.
# USE_FAKE_LLM=

# Métricas internas del modo AI (sin PII). Si AI_TRIVIA_METRICS_LOG=1 el
# logger emite eventos JSON `ai_trivia.*` por stdout para inspección manual
# en `vercel logs`.
# AI_TRIVIA_METRICS_LOG=

# Trace detallado del modo AI trivia (solo desarrollo local). Si
# AI_TRIVIA_TRACE=1, cada request a /api/v1/prompts/generate genera un archivo
# `<timestamp>_<id>.log` en `AI_TRIVIA_TRACE_DIR` (default `./logs/ai-trivia`)
# con: cache hits/misses, prompts enviados a Gemini, respuestas crudas,
# tokens consumidos, validaciones V1..V8 y resumen final.
#
# Restricciones:
# - Se desactiva automáticamente si VERCEL_ENV=production.
# - Los archivos contienen los `riddle` y respuestas completas; no commitear
#   el directorio (ya cubierto por `.gitignore`).
# AI_TRIVIA_TRACE=
# AI_TRIVIA_TRACE_DIR=

# Convex (caché persistente de adivinanzas — ver docs/tasks/backend-related-features/convex-setup/)
#
# Tras `npx convex dev`, Convex escribe en .env.local: CONVEX_DEPLOYMENT, VITE_CONVEX_URL,
# VITE_CONVEX_SITE_URL. Para el backend (Vercel Functions) añadir también CONVEX_URL con el
# mismo host que VITE_CONVEX_URL (sin prefijo VITE_; no va al bundle del navegador).
#
# CONVEX_DEPLOYMENT=dev:...
# CONVEX_URL=https://<deployment>.convex.cloud
#
# En Vercel (Preview + Production): CONVEX_URL + CONVEX_DEPLOY_KEY (Marketplace).
# CONVEX_DEPLOY_KEY solo sirve en build (`npx convex deploy`); CONVEX_URL en runtime.

# DATABASE_URL=
